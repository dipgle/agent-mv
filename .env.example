# Copy to .env and fill values. Never commit .env to git.
# Most pipelines run fully local with NO cloud key — only set keys you need.

# ─── LOCAL (no key needed) ────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
COMFY_BASE_URL=http://localhost:8188
LITELLM_BASE_URL=http://localhost:4000
# Local-dev placeholder; rotate before exposing the proxy to anything other
# than localhost. Format intentionally avoids sk-* prefix.
LITELLM_MASTER_KEY=local-dev-noauth

# ─── FREE CLOUD APIs (Tier A−, optional but recommended) ──────────────────
# These are the official free tiers — no ToS risk, no ban risk, renewed daily.
# Total combined: ~30K req/day legit free, sufficient for small commercial use.
#   Groq:       https://console.groq.com/keys             (14K req/day)
#   Cerebras:   https://cloud.cerebras.ai/                (8K req/day)
#   OpenRouter: https://openrouter.ai/keys                (rate-limited free)
#   Mistral:    https://console.mistral.ai/api-keys/      (free Codestral)
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=

# ─── OPENAI CODEX POOL (Tier S free, Adjudicator/Architect only) ──────────
# Multiple OpenAI accounts with free trial credits OR ChatGPT Plus quota.
# LiteLLM rotates across these when the active key hits 429.
# WARNING: OpenAI ToS prohibits multi-account quota stacking. Use throwaway
# accounts on dedicated IPs (residential proxy) to reduce ban cascade risk.
# Reserved for low-volume high-value roles (Adjudicator tie-break, Architect
# decision). cost_gate.py rejects high-volume callers automatically.
OPENAI_POOL_1=
OPENAI_POOL_2=
OPENAI_POOL_3=

# ─── PAID CLOUD (Tier A + S, optional) ────────────────────────────────────
# Only set if escalating to Sonnet/Opus.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── VISUAL GEN CLOUD (paid, optional, premium client only) ───────────────
# Tier S video gen — separate billing track from text LLM cap.
RUNWAY_API_KEY=
PIKA_API_KEY=
ELEVENLABS_API_KEY=

# ─── PATHS (override if non-default) ──────────────────────────────────────
# Where ComfyUI is installed (set after running setup script)
COMFY_PATH=
# Where model weights live (default: $COMFY_PATH/models/)
MODELS_PATH=
# Where rendered video output goes (default: ./out/)
OUTPUT_PATH=./out

# ─── ROUTING (quota-aware, no USD cap) ────────────────────────────────────
# Pipeline routes by REAL model quota state, not by USD budget caps.
# cost_gate.py reads MODEL_QUOTAS_FILE to pick the cheapest tier with quota
# left, and auto-cascades up when a tier returns 429 / exhausted / capability
# mismatch. Recommended starting point = minimum cost (local).
MODEL_QUOTAS_FILE=infra/quotas.json
# Hardware + electricity used by cost.py for AFTER-THE-FACT rollup (dashboard),
# not for gating. Pick the label that matches your box.
PIPELINE_HARDWARE=M3_Max_owned
ELECTRICITY_USD_KWH=0.12

# ─── EVAL DASHBOARD (eval/serve.py) ───────────────────────────────────────
# When set, every /eval/api/* request must include:
#   Authorization: Bearer <EVAL_SERVE_TOKEN>
# The dashboard JS stores the token in sessionStorage and attaches it automatically.
# Leave empty for localhost-only mode (serve.py forces --host 127.0.0.1 when unset).
# Generate a strong token: python -c "import secrets; print(secrets.token_urlsafe(32))"
EVAL_SERVE_TOKEN=

# ─── ROUTING ALERTING (supervisor/cost_rollup.py) ─────────────────────────
# Webhook fires on QUOTA events, not USD thresholds:
#   - free tier exhausted (cascade had to climb to paid)
#   - paid tier used (any non-zero $ call landed)
#   - quota refill detected (free tier returned from 429)
# Leave empty to log to devlog only (no HTTP POST).
#   Slack:   webhook URL from your Slack incoming-webhooks app
#   Discord: webhook URL from a Discord channel "Edit Channel → Integrations"
#   Generic: any endpoint that accepts POST {"text": "..."}
COST_ALERT_WEBHOOK_URL=
# Alert sensitivity. Levels:
#   info    — every cascade event
#   warn    — only when paid tier used
#   critical — only when paid spend > $1/day (heuristic, no hard cap)
COST_ALERT_LEVEL=warn
