# Copy to .env and fill values. Never commit .env to git.
# Most pipelines run fully local with NO cloud key — only set keys you need.

# ─── LOCAL (no key needed) ────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
COMFY_BASE_URL=http://localhost:8188
LITELLM_BASE_URL=http://localhost:4000
# Local-dev placeholder; rotate before exposing the proxy to anything other
# than localhost. Format intentionally avoids sk-* prefix.
LITELLM_MASTER_KEY=local-dev-noauth

# ─── FREE CLOUD APIs (Tier A−, optional but recommended) ──────────────────
# These are the official free tiers — no ToS risk, no ban risk, renewed daily.
# Total combined: ~30K req/day legit free, sufficient for small commercial use.
#   Groq:       https://console.groq.com/keys             (14K req/day)
#   Cerebras:   https://cloud.cerebras.ai/                (8K req/day)
#   OpenRouter: https://openrouter.ai/keys                (rate-limited free)
#   Mistral:    https://console.mistral.ai/api-keys/      (free Codestral)
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=

# ─── OPENAI CODEX POOL (Tier S free, Adjudicator/Architect only) ──────────
# Multiple OpenAI accounts with free trial credits OR ChatGPT Plus quota.
# LiteLLM rotates across these when the active key hits 429.
# WARNING: OpenAI ToS prohibits multi-account quota stacking. Use throwaway
# accounts on dedicated IPs (residential proxy) to reduce ban cascade risk.
# Reserved for low-volume high-value roles (Adjudicator tie-break, Architect
# decision). cost_gate.py rejects high-volume callers automatically.
OPENAI_POOL_1=
OPENAI_POOL_2=
OPENAI_POOL_3=

# ─── PAID CLOUD (Tier A + S, optional) ────────────────────────────────────
# Only set if escalating to Sonnet/Opus.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── VISUAL GEN CLOUD (paid, optional, premium client only) ───────────────
# Tier S video gen — separate billing track from text LLM cap.
RUNWAY_API_KEY=
PIKA_API_KEY=
ELEVENLABS_API_KEY=

# ─── PATHS (override if non-default) ──────────────────────────────────────
# Where ComfyUI is installed (set after running setup script)
COMFY_PATH=
# Where model weights live (default: $COMFY_PATH/models/)
MODELS_PATH=
# Where rendered video output goes (default: ./out/)
OUTPUT_PATH=./out

# ─── BUDGETS ──────────────────────────────────────────────────────────────
MONTHLY_LLM_BUDGET_USD=100
PER_VIDEO_VISUAL_CAP_USD=20
